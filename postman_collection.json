{
  "info": {
    "name": "MiniMarket Mock API v2",
    "_postman_id": "00000000-0000-0000-0000-000000000002",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "adminToken",
      "value": ""
    },
    {
      "key": "orderId",
      "value": ""
    },
    {
      "key": "lineId",
      "value": ""
    },
    {
      "key": "productId",
      "value": "p-4001"
    }
  ],
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/health",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "health"
          ]
        }
      }
    },
    {
      "name": "Login (user)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "login"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\"email\": \"test@example.com\", \"password\": \"password123\"}"
        }
      }
    },
    {
      "name": "Login (admin)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "login"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\"email\": \"admin@example.com\", \"password\": \"admin123\"}"
        }
      }
    },
    {
      "name": "Products",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/api/products?perPage=12&page=1",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "products"
          ],
          "query": [
            {
              "key": "perPage",
              "value": "12"
            },
            {
              "key": "page",
              "value": "1"
            }
          ]
        }
      }
    },
    {
      "name": "Cart (get)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/cart",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "cart"
          ]
        }
      }
    },
    {
      "name": "Cart (add item)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/cart/items",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "cart",
            "items"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\"productId\": \"{{productId}}\", \"qty\": 1}"
        }
      }
    },
    {
      "name": "Checkout",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/orders/checkout",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "orders",
            "checkout"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\"address\": {\"zip\": \"12345\", \"line1\": \"서울시 강남구 테헤란로 1\", \"line2\": \"101동 1001호\"}, \"payment\": {\"method\": \"카드\", \"card\": \"****-****-****-1234\"}, \"couponCode\": \"WELCOME10\", \"pointsUse\": 1000, \"memo\": \"문앞에 놔주세요\"}"
        }
      }
    },
    {
      "name": "Admin Overview",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/admin/overview",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "admin",
            "overview"
          ]
        }
      }
    },
    {
      "name": "Admin Orders",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/admin/orders",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "admin",
            "orders"
          ]
        }
      }
    }
  ]
}